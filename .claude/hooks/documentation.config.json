{
  "auto-review": {
    "enabled": true,
    "description": "Automatically review all documentation with editor-anti-llm agent",
    "patterns": [
      "docs/**/*.md",
      "docs/**/*.mdx",
      "*.md",
      "**/*.mdx",
      "api/documentation/**",
      "guides/**/*.md"
    ],
    "exclude": [
      "node_modules/**",
      ".git/**",
      "**/.claude/**",
      "**/CHANGELOG.md",
      "**/LICENSE.md"
    ],
    "trigger": "editor-anti-llm",
    "config": {
      "default": {
        "mode": "strict",
        "audience": "developer",
        "autoApply": true,
        "rules": {
          "noDashes": true,
          "noParallelConstructions": true,
          "defineTermsOnFirstUse": true,
          "requireSpecificExamples": true,
          "minimumInfoDensity": 0.6,
          "sentenceCase": true,
          "varyingSentenceLength": true,
          "noEmptySummaries": true,
          "noRhetoricalQuestions": true,
          "validateCodeExamples": true
        }
      },
      "overrides": {
        "README.md": {
          "mode": "strict",
          "audience": "enduser",
          "autoApply": true,
          "rules": {
            "defineTermsOnFirstUse": true,
            "requireSpecificExamples": true,
            "minimumInfoDensity": 0.6,
            "includeVersionNumbers": true
          }
        },
        "docs/api/**": {
          "mode": "strict",
          "audience": "developer",
          "autoApply": true,
          "rules": {
            "requireErrorExamples": true,
            "validateCodeExamples": true,
            "includeVersionNumbers": true
          }
        },
        "docs/guides/**": {
          "mode": "strict",
          "audience": "enduser",
          "autoApply": true,
          "rules": {
            "defineTermsOnFirstUse": true,
            "requireSpecificExamples": true,
            "noJargon": true
          }
        }
      }
    },
    "hooks": {
      "post-write": true,
      "post-edit": true,
      "pre-commit": true
    },
    "notifications": {
      "enabled": true,
      "verbose": false,
      "reportFormat": "summary"
    }
  },
  "agent-chains": {
    "documentation-generators": [
      "api-docs",
      "base-template-generator",
      "documenter"
    ],
    "auto-chain-after": "editor-anti-llm"
  },
  "performance": {
    "batchProcessing": true,
    "maxConcurrent": 3,
    "timeout": 60000
  }
}
