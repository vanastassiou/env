{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": ".*\\.md$",
        "cmd": "markdown-toc -i --maxdepth=6 ${file}"
      },
      {
        "match": ".*\\.md$",
        "cmd": "prettier --config .pre-commit-config/.config/.prettierrc.yaml --write ${file}"
      },
      {
        "match": ".*\\.md$",
        "cmd": "markdownlint --config .pre-commit-config/.config/.markdownlint.yaml --fix ${file}"
      }
    ]
  },

  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  "shellcheck.enable": true,
  "shellcheck.exclude": ["SC1091", "SC2086", "SC2154"],
  "shellcheck.run": "onSave",
  "shellcheck.customArgs": ["--rcfile=./.pre-commit-config/.config/.shellcheckrc"],

  "markdownlint.configFile": ".pre-commit-config/.config/.markdownlint.yaml",
  "prettier.configPath": ".pre-commit-config/.config/.prettierrc.yaml",

  "yaml.format.enable": true,
  "yaml.validate": true,
  "yaml.schemas": {
    ".pre-commit-config/.config/.yamllint.yaml": ["*.yaml", "*.yml"]
  }
}
